{
	"name": "@lagless/core",
	"version": "1.0.0",
	"description": "API acceleration engine - offline-first, edge-ready, framework-agnostic core",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint src --ext .ts",
		"format": "prettier --write \"src/**/*.ts\"",
		"prepublishOnly": "npm run build && npm test"
	},
	"keywords": [
		"lagless",
		"api",
		"cache",
		"offline-first",
		"sync",
		"queue",
		"deduplication",
		"retry",
		"metrics",
		"subscriptions",
		"event-bus",
		"typescript"
	],
	"author": "Lagless",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@typescript-eslint/eslint-plugin": "^8.61.0",
		"@typescript-eslint/parser": "^8.61.0",
		"@vitest/coverage-v8": "^4.1.8",
		"eslint": "^8.56.0",
		"prettier": "^3.2.4",
		"tsup": "^8.0.1",
		"typescript": "^5.3.3",
		"vitest": "^4.1.8"
	},
	"engines": {
		"node": ">=18"
	},
	"sideEffects": false
}
